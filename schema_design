write_csv(dim_channel, "dim_channel")


dim_status = (
    df_status_code
    .withColumnRenamed("play_session_status_code", "status_code")
    .withColumnRenamed("english_description", "status_name_en")
    .withColumnRenamed("french_description", "status_name_fr")
